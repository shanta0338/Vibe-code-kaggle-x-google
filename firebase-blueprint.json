{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "User profile with preference settings",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The unique user ID" },
        "email": { "type": "string", "description": "User email address" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Profile creation date" },
        "preferences": {
          "type": "object",
          "properties": {
            "defaultVoice": { "type": "string" },
            "playbackSpeed": { "type": "number" },
            "theme": { "type": "string" }
          }
        }
      },
      "required": ["userId", "email"]
    },
    "PdfSummary": {
      "title": "PdfSummary",
      "description": "A summarized PDF containing parsed contents, key takeaways, and audio logs",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique summary ID" },
        "userId": { "type": "string", "description": "Owner userId" },
        "title": { "type": "string", "description": "Title of the summary" },
        "originalFileName": { "type": "string", "description": "Original PDF name" },
        "fileSize": { "type": "number", "description": "Original file size in bytes" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" },
        "markdownContent": { "type": "string", "description": "Full structured markdown summary" },
        "readingTime": { "type": "number", "description": "Estimated reading time in minutes" },
        "tags": { "type": "array", "description": "User-assigned tags" },
        "category": { "type": "string", "description": "Auto-classified document category" },
        "keyTakeaways": { "type": "array", "description": "Highlighted key facts" },
        "flashcards": { "type": "array", "description": "Auto-generated review Q&As" }
      },
      "required": ["id", "userId", "title", "originalFileName", "createdAt", "markdownContent"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Store user specific profiles"
    },
    "/users/{userId}/summaries/{summaryId}": {
      "schema": "PdfSummary",
      "description": "Store all summarized documents for the user"
    }
  }
}
